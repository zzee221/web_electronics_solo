---
import { formatDate, getRatingColor } from '@/utils/helpers';
import CategoryBadge from '@/components/shared/CategoryBadge.astro';

interface Props {
  review: any;
}

const { review } = Astro.props;
const { title, productName, productImage, productImageAlt, rating, verdict, category, publishDate } = review.data;
---

<article class="group bg-card rounded-xl border overflow-hidden hover:shadow-lg transition-all duration-300">
  <div class="relative aspect-video overflow-hidden">
    <img
      src={productImage}
      alt={productImageAlt}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
    <div class="absolute top-4 right-4 bg-background/90 backdrop-blur-sm rounded-lg px-3 py-2">
      <span class={`text-2xl font-bold ${getRatingColor(rating)}`}>
        {rating.toFixed(1)}
      </span>
      <span class="text-sm text-muted-foreground">/10</span>
    </div>
  </div>

  <div class="p-6">
    <div class="flex items-center gap-2 mb-3">
      <CategoryBadge category={category} />
      <time class="text-xs text-muted-foreground" datetime={publishDate.toISOString()}>
        {formatDate(publishDate)}
      </time>
    </div>

    <p class="text-sm text-primary font-medium mb-2">{review.data.productBrand}</p>
    <h3 class="text-lg font-semibold mb-2 line-clamp-1">
      <a href={`/review/${review.slug}`} class="hover:text-primary transition-colors">
        {productName}
      </a>
    </h3>
    <p class="text-muted-foreground text-sm line-clamp-2">{verdict}</p>

    <a
      href={`/review/${review.slug}`}
      class="mt-4 inline-flex items-center text-primary font-medium hover:underline"
    >
      Read Full Review
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1">
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </a>
  </div>
</article>
