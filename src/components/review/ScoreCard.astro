---
import { getRatingColor, getRatingBgColor } from '@/utils/helpers';

interface Props {
  scores: {
    design: number;
    performance: number;
    value: number;
    easeOfUse: number;
    durability: number;
  };
}

const { scores } = Astro.props;

const scoreLabels: Record<string, string> = {
  design: 'Design & Build',
  performance: 'Performance',
  value: 'Value for Money',
  easeOfUse: 'Ease of Use',
  durability: 'Durability',
};
---

<div class="bg-card rounded-xl border p-6">
  <h3 class="font-semibold text-lg mb-6">Rating Breakdown</h3>
  
  <div class="space-y-5">
    {Object.entries(scores).map(([key, value]) => (
      <div class="space-y-2">
        <div class="flex justify-between text-sm">
          <span class="font-medium">{scoreLabels[key]}</span>
          <span class={getRatingColor(value)}>{value.toFixed(1)}</span>
        </div>
        <div class="h-2 bg-muted rounded-full overflow-hidden">
          <div
            class={`h-full rounded-full transition-all duration-500 ${getRatingBgColor(value)}`}
            style={`width: ${(value / 10) * 100}%`}
          ></div>
        </div>
      </div>
    ))}
  </div>
</div>
