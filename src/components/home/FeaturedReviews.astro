---
import { getCollection } from 'astro:content';
import ReviewCard from '@/components/review/ReviewCard.astro';

const allReviews = await getCollection('reviews');
const featuredReviews = allReviews
  .filter(review => review.data.featured)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
---

{featuredReviews.length > 0 && (
  <section class="py-16 bg-background">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-3xl font-bold">Featured Reviews</h2>
          <p class="text-muted-foreground mt-2">Our top-tested products this month</p>
        </div>
        <a href="/review" class="text-primary hover:underline font-medium">
          View All →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredReviews.map(review => (
          <ReviewCard review={review} />
        ))}
      </div>
    </div>
  </section>
)}
