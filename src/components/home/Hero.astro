---
import { Button } from '@/components/shared/Button';
---

<section class="relative overflow-hidden bg-gradient-to-b from-background to-muted/30">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-orange-500/10 via-transparent to-transparent"></div>
  
  <div class="container relative mx-auto px-4 py-24 md:py-32">
    <div class="max-w-4xl mx-auto text-center space-y-8">
      <div class="space-y-4 animate-in">
        <span class="inline-block px-4 py-1.5 rounded-full bg-primary/10 text-primary text-sm font-medium">
          Independent Reviews You Can Trust
        </span>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight">
          Find the Perfect <span class="text-primary">Tech Gear</span>
        </h1>
        <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
          Thoroughly tested products, honest opinions, and expert buying guides to help you make smarter purchasing decisions.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-in stagger-1">
        <a href="/review">
          <Button size="lg" className="min-w-[200px]">
            Latest Reviews
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </Button>
        </a>
        <a href="/blog">
          <Button variant="outline" size="lg" className="min-w-[200px]">
            Browse Guides
          </Button>
        </a>
      </div>

      <div class="flex items-center justify-center gap-8 pt-8 text-sm text-muted-foreground animate-in stagger-2">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
          <span>100+ Reviews</span>
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
          <span>Expert Writers</span>
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
          <span>Unbiased Opinions</span>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-background to-transparent"></div>
</section>
