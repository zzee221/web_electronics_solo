---
interface Props {
  category: string;
  size?: 'sm' | 'md';
}

const { category, size = 'md' } = Astro.props;

const categoryColors: Record<string, string> = {
  'Smart Home': 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200',
  'Portable Power': 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
  'Audio': 'bg-pink-100 text-pink-800 dark:bg-pink-900 dark:text-pink-200',
  'Outdoor Gear': 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200',
  'Wearables': 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200',
  'Accessories': 'bg-gray-100 text-gray-800 dark:bg-gray-900 dark:text-gray-200',
};

const colorClass = categoryColors[category] || 'bg-primary/10 text-primary';
---

<a
  href={`/category/${category.toLowerCase().replace(/\s+/g, '-')}`}
  class:list={[
    "inline-flex items-center rounded-full font-medium transition-colors hover:opacity-80",
    colorClass,
    size === 'sm' ? 'text-xs px-2.5 py-0.5' : 'text-sm px-3 py-1'
  ]}
>
  {category}
</a>
