---
import { formatDate } from '@/utils/helpers';
import CategoryBadge from '@/components/shared/CategoryBadge.astro';

interface Props {
  post: any;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, coverImage, coverImageAlt, category, author, publishDate, readingTime } = post.data;
---

<article class:list={[
  "group bg-card rounded-xl border overflow-hidden hover:shadow-lg transition-all duration-300",
  featured && "md:flex"
]}>
  <div class:list={[
    "relative overflow-hidden",
    featured ? "md:w-1/2 aspect-video md:aspect-auto" : "aspect-video"
  ]}>
    <img
      src={coverImage}
      alt={coverImageAlt}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>

  <div class="p-6 flex flex-col justify-center">
    <div class="flex items-center gap-3 mb-3">
      <CategoryBadge category={category} />
      <span class="text-sm text-muted-foreground">{readingTime} min read</span>
    </div>

    <h3 class:list={[
      "font-semibold mb-2 group-hover:text-primary transition-colors",
      featured ? "text-2xl" : "text-lg"
    ]}>
      <a href={`/blog/${post.slug}`}>
        {title}
      </a>
    </h3>

    <p class="text-muted-foreground mb-4 line-clamp-2">{description}</p>

    <div class="flex items-center justify-between text-sm">
      <div class="flex items-center gap-2">
        <span class="font-medium">{author}</span>
        <span class="text-muted-foreground">·</span>
        <time datetime={publishDate.toISOString()}>
          {formatDate(publishDate)}
        </time>
      </div>
    </div>
  </div>
</article>
