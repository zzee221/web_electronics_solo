---
import { SITE_CONFIG, CATEGORIES } from '@/utils/helpers';

const currentYear = new Date().getFullYear();
---

<footer class="border-t bg-muted/50">
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="space-y-4">
        <a href="/" class="flex items-center space-x-2">
          <svg class="h-8 w-8" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="6" fill="#0f172a"/>
            <path d="M8 12L16 8L24 12V20L16 24L8 20V12Z" stroke="#f97316" stroke-width="2" fill="none"/>
            <path d="M16 8V24" stroke="#f97316" stroke-width="2"/>
            <path d="M8 12L16 16L24 12" stroke="#f97316" stroke-width="2"/>
            <circle cx="16" cy="16" r="3" fill="#f97316"/>
          </svg>
          <span class="font-bold text-xl">TechPick</span>
        </a>
        <p class="text-sm text-muted-foreground">
          Independent product reviews and buying guides for tech enthusiasts. 
          Our recommendations are based on thorough testing and honest analysis.
        </p>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Categories</h3>
        <ul class="space-y-2 text-sm">
          {CATEGORIES.slice(0, 4).map(category => (
            <li>
              <a href={`/category/${category.slug}`} class="text-muted-foreground hover:text-primary transition-colors">
                {category.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Company</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="text-muted-foreground hover:text-primary transition-colors">About Us</a></li>
          <li><a href="/contact" class="text-muted-foreground hover:text-primary transition-colors">Contact</a></li>
          <li><a href="/blog" class="text-muted-foreground hover:text-primary transition-colors">Blog</a></li>
          <li><a href="/review" class="text-muted-foreground hover:text-primary transition-colors">All Reviews</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Legal</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/privacy" class="text-muted-foreground hover:text-primary transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-muted-foreground hover:text-primary transition-colors">Terms of Service</a></li>
          <li><a href="/affiliate-disclosure" class="text-muted-foreground hover:text-primary transition-colors">Affiliate Disclosure</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-muted-foreground">
          © {currentYear} {SITE_CONFIG.name}. All rights reserved.
        </p>
        <div class="flex items-center gap-6">
          <a href="/rss.xml" class="text-muted-foreground hover:text-primary transition-colors" aria-label="RSS Feed">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 11a9 9 0 0 1 9 9"></path>
              <path d="M4 4a16 16 0 0 1 16 16"></path>
              <circle cx="5" cy="19" r="1"></circle>
            </svg>
          </a>
          <a href={`https://twitter.com/${SITE_CONFIG.social.twitter}`} class="text-muted-foreground hover:text-primary transition-colors" aria-label="Twitter">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
