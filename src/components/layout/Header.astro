---
import { SITE_CONFIG } from '@/utils/helpers';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/review', label: 'Reviews' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];
---

<header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="container mx-auto flex h-16 items-center justify-between px-4">
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center space-x-2">
        <svg class="h-8 w-8" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="6" fill="#0f172a"/>
          <path d="M8 12L16 8L24 12V20L16 24L8 20V12Z" stroke="#f97316" stroke-width="2" fill="none"/>
          <path d="M16 8V24" stroke="#f97316" stroke-width="2"/>
          <path d="M8 12L16 16L24 12" stroke="#f97316" stroke-width="2"/>
          <circle cx="16" cy="16" r="3" fill="#f97316"/>
        </svg>
        <span class="hidden font-bold text-xl sm:inline-block">TechPick</span>
      </a>

      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-primary',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-primary'
                : 'text-muted-foreground'
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="flex items-center gap-4">
      <button
        class="p-2 hover:bg-accent rounded-md transition-colors"
        aria-label="Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>

      <button
        class="md:hidden p-2 hover:bg-accent rounded-md transition-colors"
        aria-label="Menu"
        id="mobile-menu-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden border-t p-4">
    <div class="flex flex-col space-y-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors hover:text-primary',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-primary'
              : 'text-muted-foreground'
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
