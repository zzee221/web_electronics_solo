---
import { getCollection } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import PostCard from '@/components/blog/PostCard.astro';

const allPosts = await getCollection('posts');
const posts = allPosts.sort((a, b) => 
  b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout
  title="Blog - Buying Guides & Expert Insights"
  description="Expert buying guides, product comparisons, and in-depth articles to help you find the best tech products."
>
  <section class="py-16 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <h1 class="text-4xl font-bold mb-4">Blog</h1>
        <p class="text-xl text-muted-foreground">
          Expert insights, buying guides, and product comparisons
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <PostCard post={post} />
        ))}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-12">
          <p class="text-muted-foreground">No articles yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
