---
import { getCollection } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ReviewCard from '@/components/review/ReviewCard.astro';

const allReviews = await getCollection('reviews');
const reviews = allReviews.sort((a, b) => 
  b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout
  title="Product Reviews"
  description="In-depth, unbiased product reviews tested by our expert team."
>
  <section class="py-16 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <h1 class="text-4xl font-bold mb-4">Product Reviews</h1>
        <p class="text-xl text-muted-foreground">
          Thoroughly tested products with honest ratings
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {reviews.map(review => (
          <ReviewCard review={review} />
        ))}
      </div>

      {reviews.length === 0 && (
        <div class="text-center py-12">
          <p class="text-muted-foreground">No reviews yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
